# AI Pentesting Daemon - Environment Variables

# Server
HOST=0.0.0.0
PORT=8888

# Redis
REDIS_URL=redis://localhost

# Database
DB_PATH=data/pentest.db

# Reports
REPORTS_DIR=reports
# ── Auth / Credentials ─────────────────────────────────────────────
# User-provided credentials for auto-login on auth-walled targets
PENTDEM_USERNAME=
PENTDEM_PASSWORD=

# Pre-authenticated session token (Bearer token, JWT, etc.)
PENTDEM_SESSION_TOKEN=

# API key for API-authenticated targets
PENTDEM_API_KEY=

# Raw cookie string for direct injection (e.g., "PHPSESSID=abc; session=xyz")
PENTDEM_COOKIE=

# ── Proxy Configuration ────────────────────────────────────────────
# Comma-separated proxy URLs (http://proxy:port, socks5://proxy:port)
PENTDEM_PROXY_LIST=

# Set to "true" to wrap curl commands with proxychains
PENTDEM_USE_PROXYCHAINS=false

# Model API Keys (all free tiers)
DEEPSEEK_API_KEY=your_deepseek_api_key
KIMI_API_KEY=your_kimi_api_key
MINIMAX_API_KEY=your_minimax_api_key
QWEN_API_KEY=your_qwen_api_key
GLM_API_KEY=your_glm_api_key
FEATHERLESS_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=